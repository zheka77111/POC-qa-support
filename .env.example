LLM_PROVIDER=mock
QUALITY_THRESHOLD=0.75
MAX_REFINEMENTS=2
KB_TOP_K=3
LOG_LEVEL=INFO

# Use only when LLM_PROVIDER=gigachat
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-Pro
EMBEDDINGS_MODEL=Embeddings-2

# Retriever weights for hybrid retrieval (values between 0 and 1, should sum to 1)
RETRIEVER_WEIGHT_CHROMA=0.5
RETRIEVER_WEIGHT_BM25=0.5

# files to load into knowledge base, can be a comma-separated list of file paths
FILES = ['dataset/kb_doc_1.md', 'dataset/kb_doc_2.md', 'dataset/kb_doc_3.md']